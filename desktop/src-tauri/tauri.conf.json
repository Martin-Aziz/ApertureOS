{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PixelForge Desktop",
  "version": "0.1.0",
  "identifier": "com.pixelforge.desktop",
  "build": {
    "beforeDevCommand": "pnpm --dir ../frontend dev --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "DESKTOP_BUILD=1 pnpm --dir ../frontend build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../../frontend/build"
  },
  "app": {
    "windows": [
      {
        "title": "PixelForge Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
